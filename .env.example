# Application
APP_NAME="FinLLM Assistant"
DEBUG=false
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://finllm:finllm@localhost:5432/finllm

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB (8001 from host; 8000 inside Docker network)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=finllm_documents

# OpenAI — required for embeddings
OPENAI_API_KEY=sk-...

# Anthropic — required for LLM generation
ANTHROPIC_API_KEY=sk-ant-...

# JWT (change before any deployment)
JWT_SECRET_KEY=change-me-before-deploying
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Storage
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=50

# Chunking
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# Retrieval
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
